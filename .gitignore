# Python Cache (NÃO arquivos de configuração)
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# Python Virtual Environments - BLOQUEIA PASTA INSTALADA
# ❌ BLOQUEIA: .venv/, venv/, ENV/ (pasta instalada)
# ✅ ENVIA: requirements.txt, setup.py, pyproject.toml (arquivos de configuração)
.venv/
venv/
ENV/

# Node - BLOQUEIA PASTA INSTALADA
# ❌ BLOQUEIA: node_modules/ (pasta instalada), .next/ (build)
# ✅ ENVIA: package.json, pnpm-lock.yaml (arquivos de configuração)
node_modules/
.next/
dist/
build/
coverage/

# Logs (dados acumulados)
*.log
logs/

# VSCode User Settings (NÃO .vscode/settings.json)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Database Files - BLOQUEIA APENAS DADOS
# ❌ BLOQUEIA: *.sqlite3, *.db (dados acumulados)
# ✅ ENVIA: init_db.py, database.py, models.py (configuração do banco)
*.sqlite3
*.sqlite
*.db
chroma.sqlite3

# Uploads (arquivos do usuário - dados acumulados)
backend/uploads/
uploads/

# Ollama Models (dados acumulados - muito grande)
# ❌ BLOQUEIA: Modelos binários compilados
# ✅ ENVIA: Scripts de download/configuração
models/ollama/
backend/models/*.bin
backend/models/*.gguf
backend/models/*.safetensors

# Cache (dados acumulados)
.cache/
*.cache
.pytest_cache/
